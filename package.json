{
  "name": "uranabot",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test --import tsx --import ./tests/unit/setup/index.ts $(find tests/unit -name '*.test.ts' -print)",
    "test:integration": "node --test --import tsx --import ./tests/integration/setup/index.ts $(find tests/integration -name '*.test.ts' -print)",
    "test:e2e": "node --test --test-isolation=none --test-concurrency=1 --import tsx --import ./tests/e2e/setup/index.ts $(find tests/e2e -name '*.test.ts' -print)",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude='tests/**' --import tsx --import ./tests/unit/setup/index.ts $(find tests/unit -name '*.test.ts' -print)",
    "test:ci": "node --test --import tsx --import ./tests/unit/setup/index.ts $(find tests/unit -name '*.test.ts' -print)",
    "schema:update:sports": "node scripts/update-sports-schema.js && npm run codegen",
    "codegen": "graphql-codegen --config codegen.ts && node scripts/fix-generated-imports.js"
  },
  "keywords": [
    "telegram",
    "bot",
    "grammy",
    "typescript",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@grammyjs/parse-mode": "^2.3.0",
    "dotenv": "^17.2.1",
    "grammy": "^1.37.0",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "^5.3.0",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-graphql-request": "^7.0.1",
    "@mtcute/node": "^0.29.6",
    "@types/node": "^24.2.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3"
  }
}
