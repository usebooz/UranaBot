# Environment Configuration
NODE_ENV=development
LOG_LEVEL=info

# Deployment Configuration
URANABOT_IMAGE=ghcr.io/usebooz/uranabot:latest

# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Telegram MTProto E2E Probe Configuration (optional)
TELEGRAM_E2E_API_ID=123456
TELEGRAM_E2E_API_HASH=your_mtproto_api_hash_here
TELEGRAM_E2E_BOT_USERNAME=your_test_bot_username
TELEGRAM_E2E_GROUP_CHAT_ID=-1001234567890
TELEGRAM_E2E_VALID_LEAGUE_ID=29915
TELEGRAM_E2E_INVALID_LEAGUE_ID=0
TELEGRAM_E2E_INVALID_REPLY_FRAGMENT=Лига не найдена
TELEGRAM_E2E_STORAGE=telegram-e2e.session
TELEGRAM_E2E_TEST_MODE=true
TELEGRAM_E2E_TIMEOUT_MS=30000
TELEGRAM_E2E_PHONE=+79991234567
TELEGRAM_E2E_PASSWORD=

# Telegram URL
TELEGRAM_URL=telegram_url

# Sports API Configuration
SPORTS_API_URL=sports_api_url
SPORTS_API_PATH=sports_api_path
SPORTS_TOURNAMENT_RPL=russia

# UranaWeb App Configuration 
URANAWEB_APP_URL=uranaweb_app_url
URANAWEB_APP_PATH=uranaweb_app_path

# Caddy Proxy Configuration
URANA_API_URL=urana_api_url
URANA_API_PATH=urana_api_path
