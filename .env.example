# Environment Configuration
NODE_ENV=development
LOG_LEVEL=info

# Deployment Configuration
URANABOT_IMAGE=ghcr.io/usebooz/uranabot:latest

# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Telegram Test MTProto
TELEGRAM_TEST_API_ID=123456
TELEGRAM_TEST_API_HASH=your_mtproto_api_hash_here
TELEGRAM_TEST_PHONE=9996620000

# Telegram URL
TELEGRAM_URL=telegram_url

# Sports API Configuration
SPORTS_API_URL=sports_api_url
SPORTS_API_PATH=sports_api_path
SPORTS_TOURNAMENT_RPL=russia

# UranaWeb App Configuration 
URANAWEB_APP_URL=uranaweb_app_url
URANAWEB_APP_PATH=uranaweb_app_path

# Caddy Proxy Configuration
URANA_API_URL=urana_api_url
URANA_API_PATH=urana_api_path
